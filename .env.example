# Telegram API Credentials (Required)
TELEGRAM_API_ID="YOUR_API_ID"  # Replace with your App api_id
TELEGRAM_API_HASH="YOUR_API_HASH" # Replace with your App api_hash
TELEGRAM_PHONE_NUMBER="YOUR_PHONE_NUMBER_WITH_COUNTRY_CODE" # Replace with your phone number

# App configuration (These are illustrative and might not be directly used by the core tracker/analyzer)
APP_TITLE="tgTrax"
APP_SHORT_NAME="tgTrax"

# Target users for tracking (Required for tracker mode, comma-separated, with or without @)
# Example: TARGET_USERS="username1,@username2,user3"
TARGET_USERS=""

# Analysis settings (used by analyzer mode, also configurable in tgTrax_config.json)
# These values in .env will override tgTrax_config.json if both are present for these specific keys
CORRELATION_THRESHOLD="0.25" # Minimum correlation coefficient for analysis
# CORRELATION_THRESHOLD_NOTIFY="0.7" # Example: ছিল macOS Notifier এর জন্য, এখন আর ব্যবহৃত হচ্ছে না

# Logging configuration (also configurable in tgTrax_config.json)
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL

# User status polling interval for the tracker (also configurable in tgTrax_config.json)
USER_STATUS_POLL_INTERVAL_SECONDS="60"

# Minimum assumed online duration (also configurable in tgTrax_config.json)
MINIMUM_ASSUMED_ONLINE_DURATION_SECONDS="30"

